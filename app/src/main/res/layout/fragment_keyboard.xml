<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Keyboard container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/keyboard_total_height"
        android:layout_gravity="top">

        <!-- Keyboard rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="@dimen/keyboard_padding"
            android:paddingEnd="@dimen/keyboard_padding"
            android:paddingTop="@dimen/keyboard_padding"
            android:paddingBottom="36dp"
            android:gravity="top">

            <!-- Row 0: Number row -->
            <LinearLayout
                android:id="@+id/keyboard_row_0"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/keyboard_row_spacing" />

            <!-- Row 1: QWERTY row -->
            <LinearLayout
                android:id="@+id/keyboard_row_1"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/keyboard_row_spacing" />

            <!-- Row 2: ASDF row -->
            <LinearLayout
                android:id="@+id/keyboard_row_2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/keyboard_row_spacing" />

            <!-- Row 3: ZXCV row -->
            <LinearLayout
                android:id="@+id/keyboard_row_3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/keyboard_row_spacing" />

            <!-- Row 4: Bottom modifier row -->
            <LinearLayout
                android:id="@+id/keyboard_row_4"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/keyboard_row_spacing" />

            <!-- Row 5: Back to Claude button row -->
            <LinearLayout
                android:id="@+id/keyboard_row_5"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
