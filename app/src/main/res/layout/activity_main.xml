<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_home_screen"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Content Area (takes remaining space) -->
    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Agent Tab Content -->
        <include layout="@layout/content_agent" />

        <!-- Keyboard Tab Content -->
        <FrameLayout
            android:id="@+id/content_keyboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/keyboard_fragment_container"
                android:name="com.haoze.claudekeyboard.ui.keyboard.KeyboardFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- Touchpad Tab Content -->
        <FrameLayout
            android:id="@+id/content_touchpad"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/touchpad_fragment_container"
                android:name="com.haoze.claudekeyboard.ui.touchpad.TouchpadFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- TV Remote Tab Content -->
        <FrameLayout
            android:id="@+id/content_tvremote"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/tvremote_fragment_container"
                android:name="com.haoze.claudekeyboard.ui.tvremote.TvRemoteFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

        <!-- Home Page Content -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/content_home"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:background="@android:color/transparent">

            <LinearLayout
                android:id="@+id/home_scroll_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/hero_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_home_hero"
                    android:elevation="4dp"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tv_home_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_home_tag"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="@string/app_name"
                        android:textAppearance="?attr/textAppearanceLabelLarge"
                        android:textColor="@color/home_on_hero"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageButton
                        android:id="@+id/btn_home_settings"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_home_icon_button"
                        android:contentDescription="@string/home_settings_title"
                        android:scaleType="centerInside"
                        android:src="@drawable/baseline_settings_24"
                        app:tint="@color/home_on_hero"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_home_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="@string/app_name"
                        android:textAppearance="?attr/textAppearanceDisplaySmall"
                        android:textColor="@color/home_on_hero"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_home_tag" />

                    <TextView
                        android:id="@+id/tv_home_subtitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/home_hero_subtitle"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/home_on_hero_variant"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_home_title" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_home_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardBackgroundColor="@color/home_soft_panel"
                        app:cardCornerRadius="22dp"
                        app:cardElevation="2dp"
                        app:strokeColor="@android:color/transparent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_home_subtitle">

                        <LinearLayout
                            android:id="@+id/status_card_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_home_status_badge"
                                android:padding="11dp"
                                android:src="@drawable/baseline_bluetooth_24"
                                android:tint="?attr/colorOnSurfaceVariant" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="14dp"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_home_status_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_connection_status"
                                    android:textAppearance="?attr/textAppearanceLabelLarge"
                                    android:textColor="?attr/colorOnSurface" />

                                <TextView
                                    android:id="@+id/tv_home_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/status_not_connected"
                                    android:textAppearance="?attr/textAppearanceBodyMedium"
                                    android:textColor="?attr/colorOnSurfaceVariant" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/baseline_chevron_right_24"
                                android:tint="?attr/colorOnSurfaceVariant" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    app:cardBackgroundColor="@color/home_card"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/home_card_stroke"
                    app:strokeWidth="1dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_home"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingHorizontal="10dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="20dp" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

        <!-- Settings Page Content -->
        <FrameLayout
            android:id="@+id/content_settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <include layout="@layout/content_settings" />

        </FrameLayout>

    </FrameLayout>

</LinearLayout>
