<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/status_bar_height"
        android:background="@color/background_status_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/status_bar_padding">

        <ImageView
            android:id="@+id/status_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_dialog_info"
            android:contentDescription="Status icon" />

        <TextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/status_waiting"
            android:textColor="@color/btn_text"
            android:textSize="@dimen/status_text_size" />

        <Button
            android:id="@+id/btn_disconnect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_disconnect"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙"
            android:textSize="18sp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- Main Content Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="@dimen/section_padding">

        <!-- Core Buttons Area (Left) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/button_padding">

            <!-- Row 1: Yes and Yes to All -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="@dimen/core_button_margin">

                <Button
                    android:id="@+id/btn_yes"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/core_button_margin"
                    android:text="@string/btn_yes"
                    android:textSize="@dimen/core_button_text_size"
                    android:background="@drawable/btn_yes"
                    android:textColor="@color/btn_text"
                    android:padding="4dp"
                    android:maxLines="2"
                    android:gravity="center" />

                <Button
                    android:id="@+id/btn_yes_to_all"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/btn_yes_to_all"
                    android:textSize="@dimen/core_button_text_size"
                    android:background="@drawable/btn_yes_to_all"
                    android:textColor="@color/btn_text"
                    android:padding="4dp"
                    android:maxLines="2"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Row 2: No and Ctrl+C -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center">

                <Button
                    android:id="@+id/btn_no"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/core_button_margin"
                    android:text="@string/btn_no"
                    android:textSize="@dimen/core_button_text_size"
                    android:background="@drawable/btn_no"
                    android:textColor="@color/btn_text"
                    android:padding="4dp"
                    android:maxLines="2"
                    android:gravity="center" />

                <Button
                    android:id="@+id/btn_ctrl_c"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/btn_ctrl_c"
                    android:textSize="@dimen/core_button_text_size"
                    android:background="@drawable/btn_ctrl_c"
                    android:textColor="@color/btn_text"
                    android:padding="4dp"
                    android:maxLines="2"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Macro Buttons Area (Right) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="6"
            android:orientation="vertical"
            android:paddingStart="@dimen/section_padding">

            <!-- Text Input Area -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/core_button_margin">

                <EditText
                    android:id="@+id/et_input_text"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:hint="@string/hint_input_text"
                    android:textColor="@color/btn_text"
                    android:textColorHint="@color/status_waiting"
                    android:textSize="16sp"
                    android:background="@drawable/btn_floating"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:imeOptions="actionSend"
                    android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 !@#$%^&amp;*()-=[]\;',./`~{}|:&quot;&lt;&gt;?_" />

                <Button
                    android:id="@+id/btn_send"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/btn_send"
                    android:textSize="16sp"
                    android:background="@drawable/btn_ctrl_c"
                    android:textColor="@color/btn_text"
                    android:paddingHorizontal="16dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_macros"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:padding="@dimen/macro_button_margin" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
