<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night theme - keep same light design for consistency -->
    <style name="Base.Theme.Claudekeyboard" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary color: sky blue -->
        <item name="colorPrimary">@color/sky_blue_accent</item>
        <item name="colorPrimaryDark">@color/sky_blue_dark</item>
        <item name="colorAccent">@color/sky_blue_accent</item>

        <!-- Background: white (same as light) -->
        <item name="android:colorBackground">@color/white</item>
        <item name="android:windowBackground">@color/white</item>

        <!-- Status bar: light sky blue -->
        <item name="android:statusBarColor">@color/sky_blue_light</item>
        <item name="android:navigationBarColor">@color/white</item>

        <!-- Text colors: black -->
        <item name="android:textColor">@color/black</item>
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">#666666</item>
    </style>
</resources>
